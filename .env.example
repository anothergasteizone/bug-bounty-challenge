# Demo login credentials.
#
# Vite only exposes variables prefixed with VITE_ to the client, and inlines
# them into the bundle at build time. Copy this file to `.env` before running
# `npm run dev` / `npm run build`:
#
#   cp .env.example .env
#
VITE_DEMO_USER_EMAIL=linda.bolt@osapiens.com
VITE_DEMO_USER_PASSWORD=1234